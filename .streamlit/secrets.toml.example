# Copy this file to .streamlit/secrets.toml and fill in your values.
# Never commit secrets.toml — it is listed in .gitignore.
#
# For Streamlit Community Cloud: paste these values in
# App Settings → Secrets (no file needed in the repo).

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Obtain credentials at: https://console.cloud.google.com/
#   1. Create a project → APIs & Services → Credentials → Create OAuth client ID
#   2. Application type: Web application
#   3. Authorised redirect URIs:
#        https://<your-app>.streamlit.app/oauth2callback   ← production
#        http://localhost:8501/oauth2callback               ← local dev
#   4. Copy the Client ID and Client secret below.

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "replace-with-a-random-string-of-at-least-32-characters"

[auth.google]
client_id = "xxxx.apps.googleusercontent.com"
client_secret = "xxxx"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# ── API Keys ──────────────────────────────────────────────────────────────────
# When these are present the sidebar key inputs are hidden.

ANTHROPIC_API_KEY = "sk-ant-..."
TMDB_API_KEY = "your-32-char-tmdb-key"
